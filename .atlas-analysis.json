  "keyFeatures": [
    "Filesystem-based routing with code-splitting and compiled routes",
    "Deploy to 30+ platforms without configuration changes",
    "Runtime-agnostic: runs on Node.js, Bun, Deno, Cloudflare Workers, and more",
    "Built-in caching layer with stale-while-revalidate support",
    "Key-value storage abstraction with 20+ drivers via unstorage",
    "Built-in SQL database layer with SQLite default and 10+ connectors",
    "Plugin system for extending server runtime behavior",
    "Scheduled and on-demand tasks with cron support",
    "Vite integration for full-stack frontend + backend builds",
    "Zero-config TypeScript support with auto-imports"
  ],
